            <pubDate>Sun, 13 Apr 2026 19:00:00 +0000</pubDate>
            <sparkle:version>10</sparkle:version>
            <sparkle:shortVersionString>1.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>What's New in v1.1 (10)</h2>
                <ul>
                    <li><b>True 16-bit integer export</b> — no more 32-bit float (RGB/32*) in Photoshop</li>
                    <li><b>4-shot FFF corrected preview + export</b> — software renderer handles 400MP lazy pipelines</li>
                    <li><b>Adjustable crop margin slider</b> — fine-tune cropping in Minimal Crop mode (0-30%)</li>
                    <li><b>ICC color profile preserved</b> — reads directly from source file metadata</li>
                </ul>
            ]]></description>
